# ============================================================
# 오리완 (O-Ri-Wan) 환경 변수 설정 파일
# 이 파일을 .env.local로 복사한 뒤, 실제 값을 채워주세요.
# cp .env.local.example .env.local
# ⚠️ 절대로 실제 API 키를 이 파일에 넣지 마세요! (git에 커밋됩니다)
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Strava OAuth ---
# https://www.strava.com/settings/api 에서 애플리케이션 등록 후 발급받으세요.
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
NEXT_PUBLIC_STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/strava/callback

# --- Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
